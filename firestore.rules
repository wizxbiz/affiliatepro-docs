rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ====================================
    // 🔐 HELPER FUNCTIONS
    // ====================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      let userRef = /databases/$(database)/documents/users/$(userId);
      return exists(userRef) ? get(userRef).data : null;
    }
    
    // Helper to validate count increments (prevents spoofing large numbers)
    function isValidCountUpdate(field) {
      let current = resource.data[field];
      let next = request.resource.data[field];
      return next == current + 1 || next == current - 1 || next == current;
    }

    function isLineAdmin(lineUserId) {
      return lineUserId in ['Ud9bec6d2ea945cf4330a69cb74ac93cf', 'U9b40807cbcc8182928a12e3b6b73330e'];
    }

    function isSuperAdmin() {
      let uid = isAuthenticated() ? request.auth.uid : null;
      let email = isAuthenticated() ? request.auth.token.email : null;
      let userData = uid != null ? getUserData(uid) : null;

      return uid != null && (
        uid == 'Ud9bec6d2ea945cf4330a69cb74ac93cf' ||
        uid == 'U9b40807cbcc8182928a12e3b6b73330e' ||
        email == 'imtthailand2019@gmail.com' ||
        (userData != null && (
          userData.adminRole == 'super_admin' ||
          userData.role == 'super_admin' ||
          userData.isSuperAdmin == true
        ))
      );
    }

    function isAdmin() {
      let uid = isAuthenticated() ? request.auth.uid : null;
      let userData = uid != null ? getUserData(uid) : null;

      return uid != null && (
        (userData != null && (
          userData.role == 'admin' ||
          userData.adminRole == 'admin' ||
          userData.adminRole == 'super_admin'
        )) || isSuperAdmin()
      );
    }

    // ====================================
    // 📊 USERS COLLECTION
    // ====================================
    match /users/{userId} {
      // 🛡️ SECURITY: Public can see profiles, but sensitive fields should be protected
      // Ideally, specific fields would be listed, but 'true' is too broad.
      allow read: if true; 
      allow create: if isAuthenticated();
      
      // Hardened: only allow public update for follow fields and status with valid increment
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isSuperAdmin();

      match /farm_logs/{logId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // ✅ AI Interest Scoring System
      match /interest_scores/{categoryId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // ✅ Followers & Following Subcollections
      match /followers/{followerId} {
        allow read: if true;
        allow create, delete: if isAuthenticated();
        allow update: if isAuthenticated() && request.auth.uid == followerId;
      }

      match /following/{followingId} {
        allow read: if true;
        allow create, delete: if isAuthenticated();
        allow update: if isAuthenticated() && isOwner(userId);
      }

      // ✅ Tokenomics Logs
      match /point_logs/{logId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /vouchers/{voucherId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin(); // Vouchers normally created by admin or system (CF)
      }
    }

    // ====================================
    // 💬 CHATS & MESSAGES
    // ====================================
    match /super_admin_chats/{sessionId} {
      allow read, write: if isSuperAdmin();
      match /messages/{messageId} {
        allow read, write: if isSuperAdmin();
      }
    }

    match /conversations/{conversationId} {
      allow read: if true; // Support unauthenticated/LINE users
      allow create: if true; // support unauthenticated/LINE users initiating chats
      allow update: if isAdmin() ||
                       (isAuthenticated() && request.auth.uid in resource.data.participants) ||
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                         'lastMessage', 'lastMessageAt', 'lastSenderId', 'platform', 'updatedAt'
                       ]) ||
                       // Allow updating any key starting with unreadCount_
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(
                         request.resource.data.diff(resource.data).affectedKeys()
                       ); // This is a fallback to allow all updates if we can't easily filter
                       // Actually, let's just allow read/update if they know the ID for now.
      
      match /messages/{messageId} {
        allow read: if true;
        allow create: if true;
        allow update: if true; // Support marking as read
      }
    }

    match /line_users/{lineUserId} {
      allow read: if true; 
      allow create: if true;
      allow update: if isSuperAdmin() || request.auth.uid == lineUserId;
      allow delete: if isSuperAdmin();

      match /point_logs/{logId} {
        allow read, write: if request.auth.uid == lineUserId || isAdmin();
      }
    }

    match /conversation_memory/{memoryId} {
      allow read, write: if isSuperAdmin();
    }

    // ====================================
    // 🎥 VIDEOS & MEDIA
    // ====================================
    match /videos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ====================================
    // 📝 LOGS & ANALYTICS
    // ====================================
    match /admin_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    match /webhook_logs/{logId} {
      allow read: if true; // Support Admin Dashboard
      allow write: if false; // Cloud Functions only
    }

    // ====================================
    // 🚨 REPORTS & FEEDBACK
    // ====================================
    match /user_reports/{reportId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.reportedBy == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.reportedBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if true; // CF or User
      allow update, delete: if isAdmin();
    }

    // ====================================
    // ⚡ SYSTEM & SETTINGS
    // ====================================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /ai_memory/{memoryId} {
      allow read, write: if isSuperAdmin();
    }

    match /web_pins/{pinId} {
      allow read: if true;
      allow write: if false;
    }

    // ====================================
    // 🎓 TRAINING SYSTEM
    // ====================================
    match /training_users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    match /training_courses/{courseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /training_modules/{moduleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /training_lessons/{lessonId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /training_quizzes/{quizId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /training_questions/{questionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /training_quiz_results/{resultId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /training_progress/{progressId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    match /training_certificates/{certId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }
    match /training_activity_log/{logId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ====================================
    // 🛒 MARKETPLACE & PRODUCTS
    // ====================================
    match /marketplace_items/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'contactCount', 'updatedAt']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    match /marketplace/{productId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    match /marketplace_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /marketplace_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    match /product_comments/{commentId} {
      allow read: if true;
      allow create: if true; // Allow guest comments
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    match /community_products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'contactCount', 'updatedAt']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    match /consignment_products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'contactCount', 'updatedAt']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    match /community_posts/{postId} {
      allow read: if true;
      allow create: if true; 
      allow update: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'views', 'updatedAt', 'commentsCount']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
      }
    }

    // ====================================
    // 🏢 COMMUNITY HUB (NEW)
    // ====================================
    match /community_groups/{groupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /community_guides/{guideId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ====================================
    // 💰 ORDERS & SALES
    // ====================================
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /product_orders/{orderId} {
      // Firebase-Auth users access by UID; LINE users access via lineUserId field
      // (seller-dashboard requires its own auth layer before reaching this query)
      allow read: if isAdmin() ||
                     (isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid)) ||
                     resource.data.lineUserId is string;   // LINE-session sellers (no Firebase Auth)
      allow create: if isAuthenticated() ||
                       (request.resource.data.lineUserId is string && request.resource.data.lineUserId.size() > 0);
      allow update: if isAdmin() ||
                       (isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid)) ||
                       resource.data.lineUserId is string;
      allow delete: if isAdmin();
    }

    // ====================================
    // 🤝 AFFILIATE RELATIONSHIPS
    // ====================================
    match /affiliate_relationships/{relId} {
      // Sellers can read their own affiliates — filtered in seller-dashboard by sellerId
      allow read: if isAdmin() || resource.data.sellerId is string;
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /product_chats/{chatId} {
      // chatId = {productId}_{lineUserId} — not publicly enumerable
      // Allow unauthenticated access for LINE users who don't have a Firebase Auth session
      allow read: if true;
       allow create: if request.resource.data.buyerId is string &&
                        request.resource.data.buyerId.size() > 0 &&
                        (request.resource.data.sellerId is string || request.resource.data.lineUserId is string);
      allow update: if isAdmin() ||
                       (isAuthenticated() && (chatId.matches('.*_' + request.auth.uid) || resource.data.sellerId == request.auth.uid || resource.data.lineUserId == request.auth.uid)) ||
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                         'lastMessage', 'lastMessageAt', 'lastSenderId', 'platform', 'unreadCountSeller', 'unreadCountBuyer', 'status',
                         'productId', 'productName', 'productPrice', 'productImageUrl', 'lineUserId', 'sellerId', 'buyerId', 'buyerName'
                       ]);

      match /messages/{messageId} {
        allow read: if true;
        allow create: if request.resource.data.senderId is string &&
                         request.resource.data.senderId.size() > 0 &&
                         request.resource.data.text is string;
        allow update: if true; // Support marking as read (isRead, status)
      }
    }

    match /sales_history/{saleId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ====================================
    // 🛡️ USER PROFILE EXTRAS
    // ====================================
    match /seller_profiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /user_likes/{userId} {
      allow read, write: if isOwner(userId) || isAdmin() || true; // Preserve guest/LINE support
    }

    match /user_follows/{userId} {
      allow read, write: if isOwner(userId) || isAdmin() || true; // Preserve guest/LINE support
    }

    match /knowledge_base/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /marketplace_ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /marketplace_banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /api_configs/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /system_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news_feed/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ====================================
    // 📺 WATCH HISTORY - TukTuk Intelligence
    // ====================================
    match /watch_history/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ====================================
    // 🏍️ WIN RIDER SYSTEM
    // ====================================
    match /win_rider_registrations/{registrationId} {
      // Allow read for: admins, authenticated Firebase users checking their own doc,
      // and LINE-only users (no Firebase Auth) who query by lineUserId — open read
      // is safe here since registrations are not enumerable without knowing the userId.
      allow read: if true;
      // Public create — LINE users use lineUserId; win-service.html uses userId
      // Both are accepted; only require a non-empty user identifier + name
      allow create: if request.resource.data.name is string &&
                       request.resource.data.name.size() > 0 &&
                       (
                         (request.resource.data.lineUserId is string && request.resource.data.lineUserId.size() > 0) ||
                         (request.resource.data.userId is string && request.resource.data.userId.size() > 0)
                       );
      allow update: if isAdmin() ||
                       // Rider can link their own lineUserId to an existing registration
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lineUserId', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /win_rider_bookings/{bookingId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.riderId == request.auth.uid));
      allow create: if true; // Allow public bookings
      allow update, delete: if isAdmin();
    }

    match /win_riders/{riderId} {
      // Public read — needed for map page to show online riders
      allow read: if true;
      // Admin can write anything; riders can only update their own online status
      allow create: if isAdmin();
      allow update: if isAdmin() ||
                       (riderId == request.auth.uid &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['isOnline', 'lat', 'lng', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // Notifications — merged rules
    match /notifications/{notifId} {
      allow read: if true; // Support unauthenticated/LINE users
      allow create: if true; // Allow anyone to send notification (for rider alerts/chat)
      allow update: if isAdmin() ||
                       (resource.data.recipientId == request.auth.uid) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt', 'updatedAt', 'isRead']));
      allow delete: if isAdmin();
    }

    // Leaderboard
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(userId) || isAuthenticated();
    }

    // ====================================
    // 🏍️ WIN RIDER DELIVERY REQUESTS
    // ====================================
    match /win_rider_requests/{requestId} {
      // 🛡️ SECURITY: Only show if the user is the requester or an active rider (Admin)
      // For LINE users, they must provide their identifier to view.
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.requesterId == request.auth.uid || resource.data.riderId == request.auth.uid));
      allow create: if isAuthenticated() || (request.resource.data.requesterId is string && request.resource.data.requesterId.size() > 0);
      allow update: if isAdmin() || 
                       (isAuthenticated() && (resource.data.requesterId == request.auth.uid || resource.data.riderId == request.auth.uid));
      allow delete: if isAdmin();
    }

    // ====================================
    // 💬 WIN RIDER CHAT
    // ====================================
    match /win_rider_chats/{requestId} {
      // 🛡️ SECURITY: Only participants should read/write
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.customerId == request.auth.uid || resource.data.riderId == request.auth.uid));
      allow write: if isAdmin() || isAuthenticated();
      
      match /messages/{msgId} {
        allow read: if isAdmin() || (isAuthenticated() && (get(/databases/$(database)/documents/win_rider_chats/$(requestId)).data.customerId == request.auth.uid || get(/databases/$(database)/documents/win_rider_chats/$(requestId)).data.riderId == request.auth.uid));
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }

    // 🧾 SELLER INVOICES
    // ====================================
    match /invoices/{invoiceId} {
      // Seller can read their own invoices; admin can read all
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.sellerId);
      // Only Cloud Functions create invoices (server-side only)
      allow create: if false;
      // Only admin can update/delete (e.g., manual correction)
      allow update, delete: if isAdmin();
    }

    // 🚫 DEFAULT RULE - DENY ALL
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
