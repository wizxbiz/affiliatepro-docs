# ── Build stage ──────────────────────────────────────────────────────────────
FROM golang:1.24-alpine AS builder

WORKDIR /app

# Cache dependencies
COPY go.mod go.sum ./
RUN go mod download

# Build binary
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o tuktuk-engine .

# ── Runtime stage ─────────────────────────────────────────────────────────────
FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=builder /app/tuktuk-engine .
# Copy service account only if present (optional — falls back to demo mode)
COPY --from=builder /app/serviceAccountKey.json* ./

ENV PORT=8080
ENV TZ=Asia/Bangkok

EXPOSE 8080

CMD ["./tuktuk-engine"]
