function createAILessonFlex(topic, content, level) {
  const levelInfo = EDUCATION_LEVELS[level] || EDUCATION_LEVELS.secondary;
  
  return {
    type: 'flex',
    altText: `๐“ เธเธ—เน€เธฃเธตเธขเธ: ${topic}`,
    contents: {
      type: 'bubble',
