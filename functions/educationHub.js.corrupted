// =====================================================
// ๐” SEARCH & RECOMMENDATION - เธเนเธเธซเธฒเนเธฅเธฐเนเธเธฐเธเธณ
// =====================================================

/**
 * เธเนเธเธซเธฒเธเธญเธฃเนเธชเธ•เธฒเธกเธเธณเธเนเธ
 */
function searchCourses(query) {
  const results = [];
  const lowerQuery = query.toLowerCase();

  Object.values(COURSES).forEach(course => {
    const subject = SUBJECTS[course.subject];
    if (
      course.title.toLowerCase().includes(lowerQuery) ||
      subject.name.toLowerCase().includes(lowerQuery) ||
      subject.nameEn.toLowerCase().includes(lowerQuery)
    ) {
      results.push({
        ...course,
        subjectName: subject.name,
        subjectIcon: subject.icon
      });
    }
  });

  return results;
}

/**
 * เนเธเธฐเธเธณเธเธญเธฃเนเธชเธ•เธฒเธกเธฃเธฐเธ”เธฑเธเนเธฅเธฐเธเธงเธฒเธกเธชเธเนเธ
 */
function recommendCourses(level, interests = []) {
  const recommended = [];

  Object.values(COURSES).forEach(course => {
    if (course.level === level) {
      const subject = SUBJECTS[course.subject];
      let score = 1;

      // เน€เธเธดเนเธกเธเธฐเนเธเธเธ–เนเธฒเธ•เธฃเธเธเธฑเธเธเธงเธฒเธกเธชเธเนเธ
      interests.forEach(interest => {
        if (subject.name.includes(interest) || subject.nameEn.toLowerCase().includes(interest.toLowerCase())) {
          score += 2;
        }
      });

      recommended.push({
        ...course,
        subjectName: subject.name,
        subjectIcon: subject.icon,
        score
      });
    }
  });

  // เน€เธฃเธตเธขเธเธ•เธฒเธกเธเธฐเนเธเธ
  return recommended.sort((a, b) => b.score - a.score);
}

// =====================================================
// ๐ค– AI EDUCATION PROMPTS - Prompt เธชเธณเธซเธฃเธฑเธ AI เธ•เธญเธเธเธณเธ–เธฒเธกเธเธฒเธฃเธจเธถเธเธฉเธฒ
// =====================================================

/**
 * เธชเธฃเนเธฒเธ System Prompt เธชเธณเธซเธฃเธฑเธ AI Tutor เธ•เธฒเธกเธฃเธฐเธ”เธฑเธเธเธฒเธฃเธจเธถเธเธฉเธฒ
 */
function getEducationSystemPrompt(level, subject, mode = 'general', grade = null) {
  const levelInfo = EDUCATION_LEVELS[level];
  const subjectInfo = SUBJECTS[subject];
  
  // เธเธณเธเธฑเธ”เธฃเธฐเธ”เธฑเธเน€เธเธเธฒเธฐ เธ.1-เธก.3 (เธ เธฒเธเธเธเธ•เธด)
  const allowedLevels = ['primary', 'secondary'];
  const effectiveLevel = allowedLevels.includes(level) ? level : 'secondary';
  
  // ๐ฏ Prompt เน€เธเธเธฒเธฐเธฃเธฐเธ”เธฑเธเธเธฑเนเธ เธ.1-เธ.6 (เธฃเธฐเธ”เธฑเธเธเธงเธฒเธกเธขเธฒเธเธ•เนเธฒเธเธเธฑเธ)
  const primaryGradePrompts = {
    'เธ.1': `๐‘ถ **เธฃเธฐเธ”เธฑเธ เธ.1 (เธญเธฒเธขเธธ 6-7 เธเธต) - เน€เธฃเธดเนเธกเธ•เนเธ**
- เนเธเนเธเธณเธเนเธฒเธขเน เธเธฃเธฐเนเธขเธเธชเธฑเนเธเธกเธฒเธ (เนเธกเนเน€เธเธดเธ 10 เธเธณ)
- เนเธเนเธฃเธนเธเธ เธฒเธ Emoji เน€เธขเธญเธฐเน ๐จ๐โจ
- เธขเธเธ•เธฑเธงเธญเธขเนเธฒเธเธเธฒเธเธเธญเธเน€เธฅเนเธ เธชเธฑเธ•เธงเน เธเธฅเนเธกเน
- เธเธกเน€เธเธขเธ—เธธเธเธเธฃเธฑเนเธ "เน€เธเนเธเธกเธฒเธ!" "เธ”เธตเธกเธฒเธเน€เธฅเธข!"
- เธ—เธงเธเธเนเธณเน€เธเธทเนเธญเธซเธฒเธชเธณเธเธฑเธ
- เนเธเนเธเธฒเธฃเธเธฑเธ 1-20, เธ•เธฑเธงเธญเธฑเธเธฉเธฃ เธ-เธฎ, A-Z`,

    'เธ.2': `๐ง’ **เธฃเธฐเธ”เธฑเธ เธ.2 (เธญเธฒเธขเธธ 7-8 เธเธต) - เธเธทเนเธเธเธฒเธ**
- เธเธฃเธฐเนเธขเธเธชเธฑเนเธ เธเธฑเธ”เน€เธเธ เน€เธเนเธฒเนเธเธเนเธฒเธข
- เธขเธเธ•เธฑเธงเธญเธขเนเธฒเธเธเธฒเธเธเนเธฒเธ เนเธฃเธเน€เธฃเธตเธขเธ เธเธฃเธญเธเธเธฃเธฑเธง
- เนเธเน Emoji เธเนเธงเธขเธญเธเธดเธเธฒเธข ๐“โ๏ธ๐’
- เธชเธนเธ•เธฃเธเธนเธ“ 2-5, เธเธฒเธฃเธญเนเธฒเธเน€เธเธตเธขเธเธเธณเธเนเธฒเธข
- เนเธซเนเธเธณเธฅเธฑเธเนเธเนเธฅเธฐเธเธกเน€เธเธข`,

    'เธ.3': `๐“– **เธฃเธฐเธ”เธฑเธ เธ.3 (เธญเธฒเธขเธธ 8-9 เธเธต) - เธเธทเนเธเธเธฒเธ+**
- เธญเธเธดเธเธฒเธขเน€เธเนเธเธเธฑเนเธเธ•เธญเธ 1-2-3
- เธขเธเธ•เธฑเธงเธญเธขเนเธฒเธเธเธฒเธเน€เธฃเธทเนเธญเธเธฃเธญเธเธ•เธฑเธง
- เธชเธนเธ•เธฃเธเธนเธ“ 2-12, เน€เธจเธฉเธชเนเธงเธเธเนเธฒเธขเน
- เธซเธฅเธฑเธเธ เธฒเธฉเธฒ: เธ•เธฑเธงเธชเธฐเธเธ” เธงเธฃเธฃเธ“เธขเธธเธเธ•เน
- เน€เธฃเธดเนเธกเธเธถเธเธเธฒเธฃเธเธดเธ”เธงเธดเน€เธเธฃเธฒเธฐเธซเนเธเนเธฒเธขเน`,

    'เธ.4': `๐“ **เธฃเธฐเธ”เธฑเธ เธ.4 (เธญเธฒเธขเธธ 9-10 เธเธต) - เธเธฅเธฒเธ**
- เธญเธเธดเธเธฒเธขเน€เธเธทเนเธญเธซเธฒเธเธฃเนเธญเธกเน€เธซเธ•เธธเธเธฅ
- เน€เธฃเธดเนเธกเนเธเนเธจเธฑเธเธ—เนเน€เธเธเธฒเธฐเธ—เธฒเธ เธเธฃเนเธญเธกเธญเธเธดเธเธฒเธขเธเธงเธฒเธกเธซเธกเธฒเธข
- เน€เธจเธฉเธชเนเธงเธ เธ—เธจเธเธดเธขเธก เธชเธกเธเธฒเธฃเธเนเธฒเธขเน
- เธเธฒเธฃเธญเนเธฒเธเธเธฑเธเนเธเธเธงเธฒเธก เน€เธเธตเธขเธเน€เธฃเธตเธขเธเธเธงเธฒเธก
- เธเธฃเธฐเธงเธฑเธ•เธดเธจเธฒเธชเธ•เธฃเน เธ เธนเธกเธดเธจเธฒเธชเธ•เธฃเนเนเธ—เธข`,

