    accounting: `๐“ เธเธฒเธฃเธเธฑเธเธเธต: เธเธฑเธเธ—เธถเธเธเธฑเธเธเธต เธเธเธเธฒเธฃเน€เธเธดเธ เธ เธฒเธฉเธต เธ•เนเธเธ—เธธเธ`,
    
    // เธเธฃเธดเธเธเธฒเธ•เธฃเธต
    engineering: `๐ญ เธงเธดเธจเธงเธเธฃเธฃเธกเธจเธฒเธชเธ•เธฃเน: Calculus, Physics, Engineering Drawing, Programming`,
    business: `๐’ผ เธเธฃเธดเธซเธฒเธฃเธเธธเธฃเธเธดเธ: เธเธฒเธฃเธเธฑเธ”เธเธฒเธฃ เธเธฒเธฃเธ•เธฅเธฒเธ” เธเธฒเธฃเน€เธเธดเธ เธ—เธฃเธฑเธเธขเธฒเธเธฃเธเธธเธเธเธฅ`,
    programming: `๐‘จโ€๐’ป เธงเธดเธ—เธขเธฒเธเธฒเธฃเธเธญเธกเธเธดเธงเน€เธ•เธญเธฃเน: Data Structures, Algorithms, OOP, Web Dev`
  };

  return `${subjectPrompts[subject] || '๐“ เธงเธดเธเธฒเธ—เธฑเนเธงเนเธ'}

๐“– เธซเธฑเธงเธเนเธญ: ${topic || 'เธ—เธฑเนเธงเนเธ'}

โ“ เธเธณเธ–เธฒเธก: ${userQuestion}

เธเธฃเธธเธ“เธฒเธ•เธญเธเธเธณเธ–เธฒเธกเธญเธขเนเธฒเธเธฅเธฐเน€เธญเธตเธขเธ” เน€เธเนเธฒเนเธเธเนเธฒเธข เธเธฃเนเธญเธกเธขเธเธ•เธฑเธงเธญเธขเนเธฒเธเธเธฃเธฐเธเธญเธ`;
}

/**
 * เธ•เธฃเธงเธเธเธฑเธเธฃเธฐเธ”เธฑเธเธเธฒเธฃเธจเธถเธเธฉเธฒเนเธฅเธฐเธงเธดเธเธฒเธเธฒเธเธเนเธญเธเธงเธฒเธก
 */
function detectEducationContext(message) {
  const msgLower = message.toLowerCase();
  
  // เธ•เธฃเธงเธเธเธฑเธเธฃเธฐเธ”เธฑเธ (เธเธณเธเธฑเธ”เน€เธเธเธฒเธฐ เธ.1 - เธก.3)
  let level = null;
  let grade = null; // ๐• เน€เธเธดเนเธก grade เธชเธณเธซเธฃเธฑเธเธฃเธฐเธเธธเธเธฑเนเธเธเธต
  
  // ๐ฏ เธ•เธฃเธงเธเธเธฑเธเธฃเธฐเธ”เธฑเธเธเธฑเนเธเธเธฃเธฐเธ–เธก (เธ.1-เธ.6) เนเธเธเธฅเธฐเน€เธญเธตเธขเธ”
  const primaryGrades = ['เธ.1', 'เธ.2', 'เธ.3', 'เธ.4', 'เธ.5', 'เธ.6'];
  for (const g of primaryGrades) {
    if (msgLower.includes(g) || msgLower.includes(g.replace('.', ''))) {
      level = 'primary';
      grade = g;
      break;
    }
  }
  
  // เธ–เนเธฒเธเธนเธ”เธ–เธถเธ "เธเธฃเธฐเธ–เธก" เธซเธฃเธทเธญ "เน€เธ”เนเธ" เนเธ•เนเนเธกเนเธฃเธฐเธเธธเธเธฑเนเธ
  if (!grade && (msgLower.includes('เธเธฃเธฐเธ–เธก') || msgLower.includes('เน€เธ”เนเธ'))) {
    level = 'primary';
    grade = null; // เนเธซเนเน€เธฅเธทเธญเธเธเธฑเนเธเน€เธญเธ
  }
  
  // ๐ฏ เธ•เธฃเธงเธเธเธฑเธเธฃเธฐเธ”เธฑเธเธเธฑเนเธเธกเธฑเธเธขเธกเธ•เนเธ (เธก.1-เธก.3)
  const secondaryGrades = ['เธก.1', 'เธก.2', 'เธก.3'];
  for (const g of secondaryGrades) {
    if (msgLower.includes(g) || msgLower.includes(g.replace('.', ''))) {
      level = 'secondary';
      grade = g;
      break;
    }
  }
  
  // เธ–เนเธฒเธเธนเธ”เธ–เธถเธ "เธกเธฑเธเธขเธก" เธซเธฃเธทเธญ "เธกเธฑเธเธขเธกเธ•เนเธ" เนเธ•เนเนเธกเนเธฃเธฐเธเธธเธเธฑเนเธ
  if (!grade && (msgLower.includes('เธกเธฑเธเธขเธกเธ•เนเธ') || (msgLower.includes('เธกเธฑเธเธขเธก') && !msgLower.includes('เธกเธฑเธเธขเธกเธเธฅเธฒเธข')))) {
    level = 'secondary';
    grade = null;
  }
  
  // โ เนเธกเนเธฃเธญเธเธฃเธฑเธ เธเธงเธ/เธเธงเธช/เธกเธซเธฒเธงเธดเธ—เธขเธฒเธฅเธฑเธข/เธก.เธเธฅเธฒเธข
  if (msgLower.includes('เธเธงเธ') || msgLower.includes('เธเธงเธช') || msgLower.includes('เธญเธฒเธเธตเธงเธฐ') || 
      msgLower.includes('เธกเธซเธฒเธฅเธฑเธข') || msgLower.includes('เธเธฃเธดเธเธเธฒ') || msgLower.includes('university') ||
      msgLower.includes('เธก.4') || msgLower.includes('เธก.5') || msgLower.includes('เธก.6') ||
      msgLower.includes('เธกเธฑเธเธขเธกเธเธฅเธฒเธข')) {
    level = null;
    grade = null;
  }
  
  // เธ•เธฃเธงเธเธเธฑเธเธงเธดเธเธฒ
  let subject = null;
  const subjectKeywords = {
    thai: ['เธ เธฒเธฉเธฒเนเธ—เธข', 'เนเธงเธขเธฒเธเธฃเธ“เน', 'เธงเธฃเธฃเธ“เธเธ”เธต', 'เธเธฒเธฃเธญเนเธฒเธ', 'เน€เธเธตเธขเธ', 'เธเธขเธฑเธเธเธเธฐ', 'เธชเธฃเธฐ', 'เธงเธฃเธฃเธ“เธขเธธเธเธ•เน'],
    math: ['เธเธ“เธดเธ•', 'เน€เธฅเธ', 'เธชเธกเธเธฒเธฃ', 'เธเธตเธเธเธ“เธดเธ•', 'เน€เธฃเธเธฒ', 'เนเธเธฅเธเธนเธฅเธฑเธช', 'เธชเธนเธ•เธฃ', 'เธเธงเธ', 'เธฅเธ', 'เธเธนเธ“', 'เธซเธฒเธฃ', 'เน€เธจเธฉเธชเนเธงเธ', 'เธ—เธจเธเธดเธขเธก', 'เธฃเนเธญเธขเธฅเธฐ'],
    science: ['เธงเธดเธ—เธขเน', 'เธงเธดเธ—เธขเธฒเธจเธฒเธชเธ•เธฃเน', 'เธเธฒเธฃเธ—เธ”เธฅเธญเธ', 'เธฃเนเธฒเธเธเธฒเธข', 'เธเธทเธ', 'เธชเธฑเธ•เธงเน', 'เธเธฅเธฑเธเธเธฒเธ', 'เธงเธเธเธฃเธเธตเธงเธดเธ•'],
    physics: ['เธเธดเธชเธดเธเธชเน', 'เนเธฃเธ', 'เธเธงเธฒเธกเน€เธฃเนเธง', 'เธเธฅเธฑเธเธเธฒเธ', 'เนเธเธเนเธฒ', 'เธเธฅเธทเนเธ'],
    chemistry: ['เน€เธเธกเธต', 'เธเธฒเธ•เธธ', 'เธชเธฒเธฃ', 'เธเธเธดเธเธดเธฃเธดเธขเธฒ', 'เธเธฃเธ”', 'เน€เธเธช'],
    biology: ['เธเธตเธงเธฐ', 'เน€เธเธฅเธฅเน', 'เธเธฑเธเธเธธ', 'เธ”เธตเน€เธญเนเธเน€เธญ', 'เธฃเธฐเธเธเธฃเนเธฒเธเธเธฒเธข'],
    english: ['เธญเธฑเธเธเธคเธฉ', 'english', 'grammar', 'vocab', 'tense', 'alphabet', 'abc'],
    social: ['เธชเธฑเธเธเธก', 'เธเธฃเธฐเธงเธฑเธ•เธด', 'เธ เธนเธกเธดเธจเธฒเธชเธ•เธฃเน', 'เน€เธจเธฃเธฉเธ', 'เธเธฃเธญเธเธเธฃเธฑเธง', 'เธเธธเธกเธเธ', 'เธเธฅเน€เธกเธทเธญเธ'],
    mechanical: ['เธเธฅเธถเธ', 'เนเธช', 'เน€เธเธทเนเธญเธก', 'เธเธฅเนเธฃเธเธเธฒเธ', 'cnc'],
    electrical: ['เนเธเธเนเธฒ', 'เธงเธเธเธฃ', 'เนเธญเธซเนเธก', 'เน€เธเธฃเธเน€เธเธญเธฃเน'],
    electronics: ['เธญเธดเน€เธฅเนเธ', 'เนเธญเธเธต', 'เนเธกเนเธเธฃ', 'เน€เธเธเน€เธเธญเธฃเน', 'arduino'],
    automotive: ['เธฃเธ–เธขเธเธ•เน', 'เน€เธเธฃเธทเนเธญเธเธขเธเธ•เน', 'เน€เธเธตเธขเธฃเน', 'เน€เธเธฃเธ', 'เธเนเธฒเธเธขเธเธ•เน'],
    computerTech: ['เธเธญเธก', 'เนเธเธฃเนเธเธฃเธก', 'เน€เธเธตเธขเธเนเธเนเธ”', 'python', 'java', 'web'],
    accounting: ['เธเธฑเธเธเธต', 'เธเธ', 'เธ เธฒเธฉเธต', 'เธ•เนเธเธ—เธธเธ', 'เธเธณเนเธฃ'],
    programming: ['coding', 'algorithm', 'data structure', 'oop']
  };
  
  for (const [subj, keywords] of Object.entries(subjectKeywords)) {
    if (keywords.some(kw => msgLower.includes(kw))) {
      subject = subj;
      break;
    }
  }
  
  return { level, subject, grade }; // ๐• เน€เธเธดเนเธก grade
}

/**
 * เธ•เธฃเธงเธเธชเธญเธเธงเนเธฒเน€เธเนเธเธเธณเธ–เธฒเธกเน€เธเธตเนเธขเธงเธเธฑเธเธเธฒเธฃเธจเธถเธเธฉเธฒเธซเธฃเธทเธญเนเธกเน
 */
function isEducationQuestion(message) {
  const msgLower = message.toLowerCase();
  
  // โ เธเธฃเธญเธเน€เธฃเธทเนเธญเธเธ—เธตเนเนเธกเนเธ•เธญเธ (เธเธตเธ”เธเธฅเธฒเธชเธ•เธดเธ, เธญเธฒเธเธตเธงเธฐ, เธกเธซเธฒเธงเธดเธ—เธขเธฒเธฅเธฑเธข)
  const excludedKeywords = [
    'เธเธตเธ”เธเธฅเธฒเธชเธ•เธดเธ', 'เธเธฅเธฒเธชเธ•เธดเธ', 'เนเธกเธฅเธ”เน', 'mold', 'injection',
    'เธเธงเธ', 'เธเธงเธช', 'เธญเธฒเธเธตเธงเธฐ', 'เธเนเธฒเธเธเธฅ', 'เธเนเธฒเธเนเธเธเนเธฒ', 'เธเนเธฒเธเธขเธเธ•เน',
    'เธเธฃเธดเธเธเธฒ', 'เธกเธซเธฒเธฅเธฑเธข', 'เธกเธซเธฒเธงเธดเธ—เธขเธฒเธฅเธฑเธข', 'university',
    'เธก.4', 'เธก.5', 'เธก.6', 'เธกเธฑเธเธขเธกเธเธฅเธฒเธข'
  ];
  
  // เธ–เนเธฒเธกเธตเธเธณเธ—เธตเนเนเธกเนเธ•เธญเธ เนเธซเน return false
  if (excludedKeywords.some(kw => msgLower.includes(kw))) {
    return false;
  }
  
  // ๐”ง เน€เธเธดเนเธก: เธเธณเธ—เธตเนเนเธกเนเนเธเน education context (false positive)
  const falsePositivePatterns = [
    'เธ—เธ”เธชเธญเธ', 'เธ—เธ”เธชเธญเธเธฃเธฐเธเธ', 'test', 'testing',
    'เนเธเนเนเธ', 'เนเธเนเธเธฑเธ', 'debug',
    'เธชเธงเธฑเธชเธ”เธต', 'hello', 'hi'
  ];
  
  if (falsePositivePatterns.some(kw => msgLower.includes(kw))) {
    return false;
  }
  
  // โ… เธ•เนเธญเธเธกเธตเธเธณเธ—เธตเนเธเนเธเธเธตเนเธฃเธฐเธ”เธฑเธเธเธฒเธฃเธจเธถเธเธฉเธฒ (เธ.1-เธก.3) เธเธฑเธ”เน€เธเธ เธซเธฃเธทเธญเธ•เนเธญเธเธกเธตเธเธณเธ–เธฒเธกเน€เธเธตเนเธขเธงเธเธฑเธเธเธฒเธฃเน€เธฃเธตเธขเธเธ—เธตเนเธเธฑเธ”เน€เธเธ
  const levelKeywords = [
    'เธ.1', 'เธ.2', 'เธ.3', 'เธ.4', 'เธ.5', 'เธ.6', 'เธเธฃเธฐเธ–เธก',
    'เธก.1', 'เธก.2', 'เธก.3', 'เธกเธฑเธเธขเธกเธ•เนเธ'
  ];
  
  // เธ–เนเธฒเธกเธตเธฃเธฐเธ”เธฑเธเธเธฑเนเธเธเธฑเธ”เน€เธเธ เนเธซเน return true เน€เธฅเธข
  if (levelKeywords.some(kw => msgLower.includes(kw))) {
    return true;
  }
  
  // โ… เธเธณเธ—เธตเนเธฃเธญเธเธฃเธฑเธ (เธ•เนเธญเธเธกเธตเธญเธขเนเธฒเธเธเนเธญเธข 2 เธเธณเธ–เธถเธเธเธฐ detect)
  const educationKeywords = [
    // เธงเธดเธเธฒเธชเธฒเธกเธฑเธ
    'เธเธ“เธดเธ•', 'เน€เธฅเธ', 'เธงเธดเธ—เธขเน', 'เธงเธดเธ—เธขเธฒเธจเธฒเธชเธ•เธฃเน',
    'เธ เธฒเธฉเธฒเนเธ—เธข', 'เธ เธฒเธฉเธฒเธญเธฑเธเธเธคเธฉ', 'เธญเธฑเธเธเธคเธฉ', 'english',
    'เธชเธฑเธเธเธก', 'เธเธฃเธฐเธงเธฑเธ•เธดเธจเธฒเธชเธ•เธฃเน', 'เธ เธนเธกเธดเธจเธฒเธชเธ•เธฃเน',
    'เธเธฅเธจเธถเธเธฉเธฒ', 'เธชเธธเธเธจเธถเธเธฉเธฒ', 'เธจเธดเธฅเธเธฐ', 'เธ”เธเธ•เธฃเธต', 'เธเธฒเธฃเธเธฒเธ',
    
    // เธเธณเธ—เธตเนเน€เธเธตเนเธขเธงเธเธฑเธเธเธฒเธฃเน€เธฃเธตเธขเธ (strict)
    'เธเนเธญเธชเธญเธ', 'เธเธฒเธฃเธเนเธฒเธ', 'เนเธเธ—เธขเน', 'เธชเธนเธ•เธฃ',
    'เธเธ—เน€เธฃเธตเธขเธ', 'เธงเธดเธเธฒ', 'เน€เธเธทเนเธญเธซเธฒ',
    'เธเธฃเธน', 'เธ•เธดเธง', 'o-net'
  ];
  
  // เธ•เนเธญเธเธกเธต keyword + เธเธณเธเธฃเธดเธขเธฒเธเธฒเธฃเน€เธฃเธตเธขเธ (เน€เธเนเธ เธชเธญเธ, เธญเธเธดเธเธฒเธข, เน€เธฃเธตเธขเธ)
  const learningVerbs = ['เธชเธญเธ', 'เธญเธเธดเธเธฒเธข', 'เน€เธฃเธตเธขเธ', 'เธ—เธณ', 'เธเนเธงเธข'];
  const hasEducationKeyword = educationKeywords.some(kw => msgLower.includes(kw));
  const hasLearningVerb = learningVerbs.some(kw => msgLower.includes(kw));
  
  // เธ•เนเธญเธเธกเธตเธ—เธฑเนเธ keyword เนเธฅเธฐ verb เธ–เธถเธเธเธฐ detect เน€เธเนเธ education
  return hasEducationKeyword && hasLearningVerb;
}

/**
 * เธชเธฃเนเธฒเธ Flex Message เธชเธณเธซเธฃเธฑเธ Study Tools เนเธ•เนเธฅเธฐเธ•เธฑเธง
 * เธญเธญเธเนเธเธเนเธซเธกเนเนเธซเนเธกเธตเธเธฑเนเธเธ•เธญเธ เนเธเธงเธ—เธฒเธ เนเธฅเธฐเธ•เธฑเธงเธญเธขเนเธฒเธเธเธณเธ–เธฒเธกเนเธเธเธซเธฅเธญเธ”เนเธ ๐’ก
 */
function createToolResponseFlex(toolId, userContext = {}) {
  // Map toolId เธ—เธตเนเธญเธฒเธเน€เธเนเธเธเธทเนเธญเธญเธทเนเธเนเธซเนเธ•เธฃเธเธเธฑเธ key เนเธ toolResponses
  const toolIdMap = {
    'flashcard': 'flashcards', 'aiflashcard': 'flashcards', 'aiFlashcard': 'flashcards',
    'summary': 'aiSummary', 'aisummary': 'aiSummary',
    'mindmap': 'mindmap', 'aiMindMap': 'mindmap', 'aimindmap': 'mindmap',
    'quiz': 'quiz', 'aiQuizGen': 'quiz', 'aiquizgen': 'quiz',
    'pomodoro': 'pomodoro', 'timer': 'pomodoro',
    'studyPlanner': 'studyPlanner', 'planner': 'studyPlanner',
    'goalTracker': 'goalTracker', 'goal': 'goalTracker',
    'formulaHelper': 'formulaHelper', 'formula': 'formulaHelper',
    'translator': 'translator', 'translate': 'translator',
    'dictionary': 'dictionary', 'dict': 'dictionary',
    'virtualLab': 'virtualLab', 'lab': 'virtualLab',
    'calculator': 'calculator', 'calc': 'calculator',
    'quizBattle': 'quizBattle', 'battle': 'quizBattle'
