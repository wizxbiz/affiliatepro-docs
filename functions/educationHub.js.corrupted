 */
function createPrimarySubjectsMenuFlex(grade) {
  const gradeInfo = GRADE_DIFFICULTY[grade];
  if (!gradeInfo) return createPrimaryGradeMenuFlex();

  // เธงเธดเธเธฒเธซเธฅเธฑเธเธชเธณเธซเธฃเธฑเธเธเธฃเธฐเธ–เธก
  const primarySubjects = [
    { id: 'math', name: 'เธเธ“เธดเธ•เธจเธฒเธชเธ•เธฃเน', icon: '๐”ข', color: '#3B82F6' },
    { id: 'thai', name: 'เธ เธฒเธฉเธฒเนเธ—เธข', icon: '๐“', color: '#EC4899' },
    { id: 'english', name: 'เธ เธฒเธฉเธฒเธญเธฑเธเธเธคเธฉ', icon: '๐ฌ๐ง', color: '#8B5CF6' },
    { id: 'science', name: 'เธงเธดเธ—เธขเธฒเธจเธฒเธชเธ•เธฃเน', icon: '๐”ฌ', color: '#10B981' },
    { id: 'social', name: 'เธชเธฑเธเธเธกเธจเธถเธเธฉเธฒ', icon: '๐', color: '#F59E0B' }
  ];

  const subjectButtons = primarySubjects.map(s => ({
    type: 'box',
    layout: 'horizontal',
    contents: [
      { type: 'text', text: s.icon, size: 'xl', flex: 0 },
      {
        type: 'box',
        layout: 'vertical',
        contents: [
          { type: 'text', text: s.name, weight: 'bold', size: 'md', color: s.color },
          { type: 'text', text: `เน€เธเธทเนเธญเธซเธฒเธฃเธฐเธ”เธฑเธ ${grade}`, size: 'xs', color: '#666666' }
        ],
        paddingStart: '12px',
        flex: 3
      },
      { type: 'text', text: 'โ–ถ', size: 'lg', color: s.color, align: 'end', flex: 1 }
    ],
    paddingAll: '12px',
    backgroundColor: '#F8FAFC',
    cornerRadius: 'md',
    margin: 'sm',
    action: { type: 'message', text: `/tutor explain เธชเธญเธ${s.name} ${grade}` }
  }));

  return {
    type: 'flex',
    altText: `๐“ เธงเธดเธเธฒ ${grade}`,
    contents: {
      type: 'bubble',
      size: 'mega',
      header: {
        type: 'box',
        layout: 'vertical',
        contents: [
          { type: 'text', text: `๐“ ${grade} - เน€เธฅเธทเธญเธเธงเธดเธเธฒ`, weight: 'bold', size: 'xl', color: '#FFFFFF' },
          { type: 'text', text: `เธฃเธฐเธ”เธฑเธ: ${gradeInfo.complexity} | เธญเธฒเธขเธธ ${gradeInfo.ageRange}`, size: 'sm', color: '#FDF4FF' }
        ],
        backgroundColor: '#EC4899',
        paddingAll: '20px'
      },
      body: {
        type: 'box',
        layout: 'vertical',
        contents: [
          { type: 'text', text: '๐“– เน€เธฅเธทเธญเธเธงเธดเธเธฒเธ—เธตเนเธ•เนเธญเธเธเธฒเธฃเน€เธฃเธตเธขเธ:', weight: 'bold', size: 'md', color: '#EC4899' },
          { type: 'separator', margin: 'md' },
