        layout: 'vertical',
        contents: [
          { type: 'text', text: `๐“ ${topic}`, weight: 'bold', size: 'lg', color: '#FFFFFF', wrap: true },
          { type: 'text', text: `${levelInfo.icon} ${levelInfo.name}`, size: 'sm', color: '#DBEAFE' }
        ],
        backgroundColor: levelInfo.color,
        paddingAll: '20px'
      },
      body: {
        type: 'box',
        layout: 'vertical',
        contents: [
          { type: 'text', text: content.substring(0, 800) + (content.length > 800 ? '...' : ''), size: 'sm', color: '#374151', wrap: true }
        ],
        paddingAll: '20px'
      },
      footer: {
        type: 'box',
        layout: 'vertical',
