          },
          {
            type: 'button',
            action: { type: 'message', label: '๐  เธเธฅเธฑเธเน€เธกเธเธนเธซเธฅเธฑเธ', text: '/edu' },
            style: 'secondary',
            height: 'sm',
            margin: 'sm'
          }
        ],
