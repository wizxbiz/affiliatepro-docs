          { type: 'button', action: { type: 'message', label: '๐’ฌ เธ–เธฒเธก WiT', text: `/tutor explain เธชเธญเธ ${grade}` }, style: 'primary', color: '#16A34A', height: 'sm', flex: 1, margin: 'sm' }
