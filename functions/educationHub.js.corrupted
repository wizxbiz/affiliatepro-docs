        },
        footer: {
          type: 'box',
          layout: 'horizontal',
          contents: [
            {
              type: 'button',
              action: { type: 'message', label: '๐ฎ เน€เธฃเธดเนเธกเนเธเนเธ', text: 'เน€เธฃเธดเนเธกเนเธเนเธ Quiz Battle เธงเธดเธเธฒเธเธ“เธดเธ•เธจเธฒเธชเธ•เธฃเน เธฃเธฐเธ”เธฑเธ เธก.เธ•เนเธ' },
              style: 'primary',
              color: '#DC2626',
              height: 'sm',
              flex: 1
            },
            {
              type: 'button',
              action: { type: 'message', label: '๐ Leaderboard', text: '/edu leaderboard' },
              style: 'secondary',
              height: 'sm',
              flex: 1,
              margin: 'sm'
            }
          ],
          paddingAll: '15px',
          backgroundColor: '#FAFAFA'
        }
      }
    }
  };

  return toolResponses[mappedToolId] || null;
}

