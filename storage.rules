rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Community posts images - public read, authenticated write
    match /community/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Allow uploads from web
    }
    
    // Marketplace images
    match /marketplace/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // Download center files - public read, allow write for admin uploads
    match /downloads/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Admin uploads via PIN verification on client
    }
    
    // Ads images - public read and write for ad creation
    match /ads/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Allow ad uploads from web
    }
    
    // Community posts images (multi-upload) - PUBLIC READ, ANYONE WRITE
    match /community_posts/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // User uploads
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // WIN RIDER document uploads — LINE users are not Firebase Auth'd
    match /win_rider_docs/{allPaths=**} {
      allow read: if request.auth != null; // private — only authenticated users
      allow write: if true;               // LINE users can upload docs
    }

    // Subscription / KYC slips
    match /subscription_slips/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /kyc_documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Default: deny all other paths
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
